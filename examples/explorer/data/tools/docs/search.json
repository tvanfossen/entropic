{
  "name": "search",
  "description": "Search documentation for a keyword or phrase. Returns top matches from functions, classes, and descriptions.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "Search query (keyword or phrase)."
      },
      "limit": {
        "type": "integer",
        "description": "Maximum number of results (default 10).",
        "default": 10
      }
    },
    "required": ["query"]
  }
}
