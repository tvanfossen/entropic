root    ::= "{" ws summary-obj ws "}"
summary-obj ::= key-facts "," ws preserved "," ws dropped
key-facts   ::= "\"key_facts\":" ws str-array
preserved   ::= "\"preserved_tool_results\":" ws str-array
dropped     ::= "\"dropped\":" ws str-array

str-array   ::= "[" ws "]"
             | "[" ws string (ws "," ws string)* ws "]"

string      ::= "\"" ([^"\\] | "\\" .)* "\""
ws          ::= [ \t\n]*
