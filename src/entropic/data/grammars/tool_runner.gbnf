# tool_runner grammar is dynamically generated at runtime from registered tools.
# This file documents the structure; the actual grammar is built by
# entropic.prompts.build_tool_runner_grammar() using list_tools() output.
#
# Structure:
#   root      ::= tool_call+
#   tool_call ::= "<tool_call>" ws "{" ws
#                   "\"name\":" ws tool_name "," ws
#                   "\"arguments\":" ws object
#                 ws "}" ws "</tool_call>"
#   tool_name ::= "\"server.tool_a\"" | "\"server.tool_b\"" | ...
#
# The tool_name enum and argument schemas are injected at runtime.
# See entropic.prompts.build_tool_runner_grammar for the builder.
