PROJECT_NAME           = "Entropic"
PROJECT_NUMBER         = 2.1.0
PROJECT_BRIEF          = "Local-first agentic inference engine"
OUTPUT_DIRECTORY       = build/docs
INPUT                  = README.md include/entropic src
USE_MDFILE_AS_MAINPAGE = README.md
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.hpp *.cpp *.md
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_SQLITE3       = YES
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_COLORSTYLE        = LIGHT
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
EXCLUDE_PATTERNS       = */extern/* */build/* */tests/* */examples/*/.venv/*
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_FROM_PATH        = include src
STRIP_FROM_INC_PATH    = include
