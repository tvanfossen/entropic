.env
.env.local
# test-reports — only the developer-run model-test snapshot is tracked
# (refreshed at each x.y.0 bump per CLAUDE.md test gating). Everything
# else under here is runtime output: per-test logs, coverage HTML,
# cache/flag files. Three-rule sandwich excludes everything except
# model/results.json.
test-reports/*
!test-reports/model/
test-reports/model/*
!test-reports/model/results.json

.claude/tmp/

examples/hello-world/.hello-world/

# Git worktrees for delegation isolation
.worktrees/

# Archived legacy files
.old/


# build cache
.cache/

# CTest scratch (CMake redirects this under build/, keep root rule as legacy)
Testing/

# Generated Doxygen output — Doxyfile OUTPUT_DIRECTORY = build/docs
# Legacy paths kept so stale generators or bare `doxygen` from CWD
# don't sneak artifacts into git.
build/docs/
html/
latex/
sqlite3/
api/

# Release tarballs
dist/
