PROJECT_NAME           = "Entropic"
PROJECT_NUMBER         = 2.0.0
PROJECT_BRIEF          = "Entropic inference engine"
OUTPUT_DIRECTORY       = api
INPUT                  = ../include/entropic ../src
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.hpp *.cpp
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_SQLITE3       = YES
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
EXCLUDE_PATTERNS       = */extern/* */build/*
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_FROM_PATH        = ../include ../src
STRIP_FROM_INC_PATH    = ../include
