{
  "version": 6,
  "cmakeMinimumRequired": {"major": 3, "minor": 21, "patch": 0},
  "configurePresets": [
    {
      "name": "full",
      "displayName": "Full (CUDA shared)",
      "description": "Full featured CUDA build for TUI developer workstation",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENTROPIC_CUDA": "ON",
        "ENTROPIC_SHARED": "ON",
        "ENTROPIC_BUILD_TESTS": "ON",
        "ENTROPIC_BUILD_MODEL_TESTS": "ON"
      }
    },
    {
      "name": "minimal-static",
      "displayName": "Minimal static (CPU embedded)",
      "description": "Minimal static build for embedded consumer",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel",
        "ENTROPIC_STATIC": "ON",
        "ENTROPIC_CPU_ONLY": "ON",
        "ENTROPIC_SHARED": "OFF",
        "ENTROPIC_MCP_BASH": "OFF",
        "ENTROPIC_MCP_GIT": "OFF",
        "ENTROPIC_MCP_WEB": "OFF",
        "ENTROPIC_MCP_DIAGNOSTICS": "OFF",
        "ENTROPIC_STORAGE_SQLITE": "OFF",
        "ENTROPIC_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "game",
      "displayName": "Game engine (CUDA minimal servers)",
      "description": "Game engine integration with CUDA and minimal MCP servers",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENTROPIC_CUDA": "ON",
        "ENTROPIC_SHARED": "ON",
        "ENTROPIC_MCP_BASH": "OFF",
        "ENTROPIC_MCP_GIT": "OFF",
        "ENTROPIC_MCP_WEB": "OFF",
        "ENTROPIC_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "dev",
      "displayName": "Development (CPU debug)",
      "description": "Fast iteration: CPU-only, debug, tests, docs",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENTROPIC_CPU_ONLY": "ON",
        "ENTROPIC_BUILD_TESTS": "ON",
        "ENTROPIC_BUILD_DOCS": "OFF"
      }
    },
    {
      "name": "asan-ubsan",
      "displayName": "ASan + UBSan (CI only)",
      "description": "AddressSanitizer + UndefinedBehaviorSanitizer. CI-only — 2-3x slowdown.",
      "inherits": "dev",
      "cacheVariables": {
        "CMAKE_C_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer",
        "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined",
        "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=address,undefined"
      }
    },
    {
      "name": "tsan",
      "displayName": "TSan (CI only)",
      "description": "ThreadSanitizer. CI-only — 5-15x slowdown. Mutually exclusive with ASan.",
      "inherits": "dev",
      "cacheVariables": {
        "CMAKE_C_FLAGS": "-fsanitize=thread",
        "CMAKE_CXX_FLAGS": "-fsanitize=thread",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=thread",
        "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=thread"
      }
    },
    {
      "name": "msan",
      "displayName": "MSan (CI only)",
      "description": "MemorySanitizer. CI-only. Requires all linked libraries instrumented — scoped to non-inference libs if llama.cpp MSan build is impractical.",
      "inherits": "dev",
      "cacheVariables": {
        "CMAKE_C_FLAGS": "-fsanitize=memory -fno-omit-frame-pointer",
        "CMAKE_CXX_FLAGS": "-fsanitize=memory -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=memory",
        "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=memory"
      }
    },
    {
      "name": "coverage",
      "displayName": "Coverage (gcov)",
      "description": "Debug build with gcov instrumentation. Mutually exclusive with sanitizers.",
      "inherits": "dev",
      "cacheVariables": {
        "ENTROPIC_COVERAGE": "ON"
      }
    }
  ],
  "buildPresets": [
    {"name": "full",           "configurePreset": "full"},
    {"name": "minimal-static", "configurePreset": "minimal-static"},
    {"name": "game",           "configurePreset": "game"},
    {"name": "dev",            "configurePreset": "dev"},
    {"name": "asan-ubsan",     "configurePreset": "asan-ubsan"},
    {"name": "tsan",           "configurePreset": "tsan"},
    {"name": "msan",           "configurePreset": "msan"},
    {"name": "coverage",       "configurePreset": "coverage"}
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": {"outputOnFailure": true}
    },
    {
      "name": "asan-ubsan",
      "configurePreset": "asan-ubsan",
      "output": {"outputOnFailure": true}
    },
    {
      "name": "tsan",
      "configurePreset": "tsan",
      "output": {"outputOnFailure": true}
    },
    {
      "name": "msan",
      "configurePreset": "msan",
      "output": {"outputOnFailure": true}
    },
    {
      "name": "coverage",
      "configurePreset": "coverage",
      "output": {"outputOnFailure": true}
    }
  ]
}
