PROJECT_NAME           = "Entropic"
# v2.1.2 (#4): PROJECT_NUMBER is injected at build time from the repo-root
# VERSION file (single source of truth shared with CMakeLists.txt and
# pyproject.toml). docs.yml and any local docs build pipe an override
# line after this Doxyfile via doxygen's stdin-update mechanism, e.g.:
#   ( cat Doxyfile ; echo "PROJECT_NUMBER=$(cat VERSION)" ) | doxygen -
# Leaving PROJECT_NUMBER unset here so a forgotten injection step shows
# as a missing version string in the rendered docs (loud failure) rather
# than silently rendering a stale literal (the v2.1.1 docs site still
# renders 2.1.0 because of exactly that drift).
PROJECT_BRIEF          = "Local-first agentic inference engine"
OUTPUT_DIRECTORY       = build/docs
INPUT                  = README.md include/entropic src
USE_MDFILE_AS_MAINPAGE = README.md
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.hpp *.cpp *.md
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_SQLITE3       = YES
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_COLORSTYLE        = LIGHT
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
EXCLUDE_PATTERNS       = */extern/* */build/* */tests/* */examples/*/.venv/*
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_FROM_PATH        = include src
STRIP_FROM_INC_PATH    = include
